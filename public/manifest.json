{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "version": "1.0.15",
  "default_locale": "zh_CN",
  "description": "__MSG_appDescription__",
  "permissions": [
    "storage",
    "contextMenus",
    "sidePanel",
    "activeTab",
    "tabs",
    "notifications",
    "favicon",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "__MSG_appName__",
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  }
}

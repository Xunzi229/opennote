{
  "manifest_version": 3,
  "name": "OpenNote",
  "version": "1.0.1",
  "description": "Website-specific notes in a right sidebar",
  "permissions": ["storage", "contextMenus", "sidePanel", "activeTab", "tabs", "notifications", "favicon", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "OpenNote",
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  }
}